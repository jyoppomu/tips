{
  "name": "tips",
  "version": "1.0.0",
  "description": "## Link to deployed page",
  "main": "index.js",
  "type": "module",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "prebuild:slides": "rimraf --glob site/slides",
    "build:slides": "marp --config .marprc.yml -I slides/src -o site/slides",
    "postbuild:slides": "node scripts/assets.mjs --src slides/src --out site/slides",
    "prebuild:docs": "rimraf --glob site",
    "build:docs": "poetry run mkdocs build -d site",
    "build:site": "failsafe build:docs build:slides",
    "create:zenn": "zenn new:article",
    "create:qiita": "qiita new",
    "preview:slides": "marp slides/src --config .marprc.yml --server",
    "preview:docs": "echo \"Error: no preview command specified for docs\" && exit 1",
    "preview:zenn": "zenn preview --port 3000",
    "preview:qiita": "qiita preview",
    "prepare": "npm-run-all prepare:*",
    "prepare:husky": "husky",
    "z2q": "tsx scripts/z2q.ts",
    "check": "tsc --noEmit",
    "pretest": "failsafe check",
    "test": "vitest run"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,json,yml,yaml,md,css,toml}": "prettier --write"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aYukiYoshida/tips.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/aYukiYoshida/tips/issues"
  },
  "homepage": "https://github.com/aYukiYoshida/tips#readme",
  "dependencies": {
    "@kazumatu981/markdown-it-kroki": "^1.3.6",
    "@marp-team/marp-cli": "^4.2.3",
    "@marp-team/marp-core": "^4.2.0",
    "@qiita/qiita-cli": "^1.7.0",
    "commander": "^14.0.2",
    "markdown-it-attrs": "^4.3.1",
    "markdown-it-container": "^4.0.0",
    "markdown-it-ins": "^4.0.0",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-prism": "^2.3.1",
    "rimraf": "^6.0.1",
    "zenn-cli": "^0.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "npm-failsafe": "^1.4.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.4.2",
    "prettier-plugin-toml": "^2.0.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
npx lint-staged

# 500KiB以上のファイルの新規追加を防止
MAX_BYTES=512000
EXIT_CODE=0
ADDED_FILES=$(git diff --cached --name-only --diff-filter=A)

if [ -n "$ADDED_FILES" ]; then
  while IFS= read -r file; do
    [ -z "$file" ] && continue
    [ ! -f "$file" ] && continue
    size=$(wc -c < "$file" | tr -d ' ')
    if [ "$size" -gt "$MAX_BYTES" ]; then
      echo "ERROR: $file is $size bytes (exceeds $MAX_BYTES bytes limit)" >&2
      EXIT_CODE=1
    fi
  done <<EOF
$ADDED_FILES
EOF
fi

exit $EXIT_CODE
